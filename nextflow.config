manifest {
    name = 'exp383/cell-x-strain-rnaseq'
    version = '0.1.0'
}

workDir = System.getenv('NXF_WORK') ?: '/media/tmurphy/2TB_SSD/exp383/nfcore_rnaseq_work/default'
cleanup = false

executor {
    cpus = 20
    memory = 60.GB
}

conda {
    cacheDir = System.getenv('NXF_CONDA_CACHEDIR') ?: '/media/tmurphy/2TB_SSD/exp383/nf_conda_cache'
}

process {
    shell = ['/bin/bash', '-euo', 'pipefail']
    resourceLimits = [cpus: 20, memory: 60.GB, time: 72.h]

    withName: '.*:FASTQ_SUBSAMPLE_FQ_SALMON:SALMON_QUANT' {
        cpus = 6
        memory = 24.GB
        time = 4.h
    }

    withName: '.*:QUANTIFY_PSEUDO_ALIGNMENT:SALMON_QUANT' {
        cpus = 6
        memory = 24.GB
        time = 12.h
    }

    withName: '.*:SORTMERNA_INDEX' {
        cpus = 8
        memory = 48.GB
        time = 16.h
    }

    withName: '.*:SORTMERNA' {
        cpus = 6
        memory = 24.GB
        time = 12.h
    }

    withName: '.*:BOWTIE2_BUILD' {
        cpus = 8
        memory = 48.GB
        time = 8.h
    }
}
